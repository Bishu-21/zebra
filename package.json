{
  "name": "zebra-ai",
  "private": true,
  "packageManager": "bun@1.2.20",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "db:generate": "turbo run db:generate --filter=@zebra/db",
    "db:migrate": "turbo run db:migrate --filter=@zebra/db"
  },
  "devDependencies": {
    "turbo": "^2.0.4",
    "typescript": "^5.5.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "dependencies": {
    "@ai-sdk/google": "^3.0.33",
    "@ai-sdk/openai": "^3.0.36",
    "@clerk/nextjs": "^6.39.0",
    "ai": "^6.0.104",
    "web": "^0.0.2",
    "zod": "^4.3.6"
  }
}